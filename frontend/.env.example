# Hubly API
# Local frontend + local backend:
NEXT_PUBLIC_API_URL=http://localhost:3333

# If the frontend runs in the browser and backend is exposed by Docker on port 3333,
# keep the same URL above. Do not use http://backend:3333 here because this value
# is used by the browser, not by the Docker network.

# Build info shown in the UI. Optional for local development.
NEXT_PUBLIC_APP_COMMIT_SHA=local
NEXT_PUBLIC_APP_LAYER_LABEL=local
