# Hubly test deployment
BACKEND_IMAGE=ghcr.io/sidneyjfg/hubly-backend:latest
FRONTEND_IMAGE=ghcr.io/sidneyjfg/hubly-frontend:latest
APP_PUBLIC_HOST=localhost
PUBLIC_API_BASE_URL=http://localhost:3333
PUBLIC_WEB_APP_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000

# HTTP
HTTP_HOST=0.0.0.0
HTTP_PORT=3333

# Database
# MySQL running on the server host, accessed from Docker containers.
DB_TYPE=mysql
DB_HOST=host.docker.internal
DB_PORT=3306
DB_NAME=hubly_test
DB_USERNAME=hubly
DB_PASSWORD=fg01032003
DB_LOGGING=false

# JWT
JWT_ACCESS_SECRET=hubly-test-access-secret-change-me
JWT_REFRESH_SECRET=hubly-test-refresh-secret-change-me
SYSTEM_ADMIN_JWT_SECRET=hubly-test-system-admin-secret-change-me
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
SYSTEM_ADMIN_ACCESS_EXPIRES_IN=10m
SYSTEM_ADMIN_EMAIL=owner@hubly.local
SYSTEM_ADMIN_PASSWORD_HASH=

# Security
LOGIN_RATE_LIMIT_WINDOW_MS=60000
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5
LOGIN_BRUTE_FORCE_THRESHOLD=8
LOGIN_BRUTE_FORCE_BLOCK_MS=900000
PASSWORD_RECOVERY_RATE_LIMIT_WINDOW_MS=60000
PASSWORD_RECOVERY_RATE_LIMIT_MAX_ATTEMPTS=3
CRITICAL_ROUTE_RATE_LIMIT_WINDOW_MS=60000
CRITICAL_ROUTE_RATE_LIMIT_MAX_ATTEMPTS=20

# Redis
REDIS_ENABLED=true
REDIS_URL=redis://redis:6379
REDIS_KEY_PREFIX=hubly_test
REDIS_CONNECT_TIMEOUT_MS=10000

# WhatsApp / Evolution API disabled in this test stack.
WHATSAPP_EVOLUTION_ENABLED=false
WHATSAPP_EVOLUTION_BASE_URL=
WHATSAPP_EVOLUTION_AUTH_HEADER_NAME=apikey
WHATSAPP_EVOLUTION_AUTH_HEADER_VALUE=
WHATSAPP_EVOLUTION_INSTANCE=
WHATSAPP_EVOLUTION_TIMEOUT_MS=10000

# Stripe kept in test mode with no keys configured.
STRIPE_BILLING_MODE=test
STRIPE_TEST_SECRET_KEY=
STRIPE_TEST_WEBHOOK_SECRET=
STRIPE_TEST_PUBLISHABLE_KEY=
STRIPE_LIVE_SECRET_KEY=
STRIPE_LIVE_WEBHOOK_SECRET=
STRIPE_LIVE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=
STRIPE_CONNECT_RETURN_URL=http://localhost:3000/settings?payments=return
STRIPE_CONNECT_REFRESH_URL=http://localhost:3000/settings?payments=refresh

# Frontend build-time public variables.
NEXT_PUBLIC_API_URL=http://localhost:3333
NEXT_PUBLIC_APP_COMMIT_SHA=main
NEXT_PUBLIC_APP_LAYER_LABEL=test
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
