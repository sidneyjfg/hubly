# HTTP
HTTP_HOST=0.0.0.0
HTTP_PORT=3333
CORS_ALLOWED_ORIGINS=http://localhost:3000
PUBLIC_API_BASE_URL=http://localhost:3333
PUBLIC_WEB_APP_URL=http://localhost:3000

# Database
# Default for backend running in Docker and MySQL running on the host machine.
# If you add a MySQL service to the same Docker network, use DB_HOST=mysql.
# If you run the backend directly on the host, use DB_HOST=127.0.0.1.
DB_TYPE=mysql
DB_HOST=host.docker.internal
DB_PORT=3306
DB_NAME=hubly
DB_USERNAME=root
DB_PASSWORD=
DB_LOGGING=false

# JWT
JWT_ACCESS_SECRET=change-access-secret
JWT_REFRESH_SECRET=change-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# System owner admin
# Generate the hash with: npm --prefix backend run hash:password -- <password>
# Until this hash is configured, /v1/system-admin/auth/sign-in returns 503.
SYSTEM_ADMIN_EMAIL=owner@hubly.local
SYSTEM_ADMIN_PASSWORD_HASH=
SYSTEM_ADMIN_JWT_SECRET=change-system-admin-secret
SYSTEM_ADMIN_ACCESS_EXPIRES_IN=10m

# Security
LOGIN_RATE_LIMIT_WINDOW_MS=60000
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5
LOGIN_BRUTE_FORCE_THRESHOLD=8
LOGIN_BRUTE_FORCE_BLOCK_MS=900000
PASSWORD_RECOVERY_RATE_LIMIT_WINDOW_MS=60000
PASSWORD_RECOVERY_RATE_LIMIT_MAX_ATTEMPTS=3
CRITICAL_ROUTE_RATE_LIMIT_WINDOW_MS=60000
CRITICAL_ROUTE_RATE_LIMIT_MAX_ATTEMPTS=20

# Redis
REDIS_ENABLED=true
REDIS_URL=redis://redis:6379
REDIS_KEY_PREFIX=hubly
REDIS_CONNECT_TIMEOUT_MS=10000

# WhatsApp / Evolution API
WHATSAPP_EVOLUTION_ENABLED=true
WHATSAPP_EVOLUTION_BASE_URL=http://evolution-api:8080
WHATSAPP_EVOLUTION_AUTH_HEADER_NAME=apikey
WHATSAPP_EVOLUTION_AUTH_HEADER_VALUE=
WHATSAPP_EVOLUTION_INSTANCE=hubly-main
WHATSAPP_EVOLUTION_TIMEOUT_MS=10000

# Stripe
# Webhook endpoint: ${PUBLIC_API_BASE_URL}/v1/public/payments/stripe/webhooks
STRIPE_BILLING_MODE=test

# Test mode keys
STRIPE_TEST_SECRET_KEY=
STRIPE_TEST_WEBHOOK_SECRET=
STRIPE_TEST_PUBLISHABLE_KEY=

# Live mode keys
STRIPE_LIVE_SECRET_KEY=
STRIPE_LIVE_WEBHOOK_SECRET=
STRIPE_LIVE_PUBLISHABLE_KEY=

# Legacy fallback variables. Prefer the mode-specific variables above.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# Stripe product_id and price_id for Pro (R$69,90) and Premium (R$129,90)
# are managed in the owner panel: /dono -> Planos.

# Stripe Connect for businesses receiving online payments
STRIPE_CONNECT_RETURN_URL=http://localhost:3000/settings?stripe=return
STRIPE_CONNECT_REFRESH_URL=http://localhost:3000/settings?stripe=refresh
