# Evolution API server
SERVER_TYPE=http
SERVER_PORT=8080
SERVER_URL=http://localhost:8080

# Authentication for Evolution API itself
# If your setup does not require it, leave empty.
AUTHENTICATION_API_KEY=mude-me

# Database
# The project assumes your main MySQL server already exists outside Docker.
# Create a separate database/schema for Evolution API and point the URI below to it.
DATABASE_ENABLED=true
DATABASE_PROVIDER=mysql
DATABASE_CONNECTION_URI=mysql://root:@host.docker.internal:3306/evolution

# Redis
CACHE_REDIS_ENABLED=true
CACHE_REDIS_URI=redis://redis:6379/6
CACHE_REDIS_PREFIX_KEY=evolution
CACHE_REDIS_SAVE_INSTANCES=true
CACHE_LOCAL_ENABLED=false

# Optional quality-of-life flags
LOG_LEVEL=ERROR,WARN,INFO,LOG
CONFIG_SESSION_PHONE_CLIENT=Clinity
CONFIG_SESSION_PHONE_NAME=Chrome
